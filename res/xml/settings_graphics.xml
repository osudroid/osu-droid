<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="@string/opt_category_skin">

        <com.reco1l.osu.ui.SelectPreference
                android:entries="@array/placeholder_array"
                android:entryValues="@array/placeholder_array"
                android:key="skinPath"
                android:summary="@string/opt_skinpath_summary"
                android:title="@string/opt_skinpath_title" />

        <Preference
                android:key="hud_editor"
                android:summary="@string/opt_hudEditor_summary"
                android:title="@string/opt_hudEditor_title"
                app:layout="@layout/settings_preference" />

        <com.reco1l.osu.ui.SelectPreference
                android:defaultValue="1"
                android:entries="@array/spinner_style_names"
                android:entryValues="@array/spinner_style_values"
                android:key="spinnerstyle"
                android:summary="@string/opt_spinner_style_summary"
                android:title="@string/opt_spinner_style_title" />

        <CheckBoxPreference
                android:defaultValue="false"
                android:key="skin"
                android:summary="@string/opt_skin_summary"
                android:title="@string/opt_skin_title"
                app:layout="@layout/settings_preference_checkbox_bottom" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/opt_category_cursor">

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="showcursor"
            android:summary="@string/opt_showcursor_summary"
            android:title="@string/opt_showcursor_title"
            app:layout="@layout/settings_preference_checkbox" />

        <com.rian.osu.ui.EditableSeekBarPreference
            android:defaultValue="50"
            android:key="cursorSize"
            android:max="300"
            android:summary="@string/opt_cursor_size_summary"
            android:title="@string/opt_cursor_size"
            app:min="25"
            app:showSeekBarValue="true"
            app:layout="@layout/settings_preference_seekbar" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="particles"
            android:summary="@string/opt_particles_summary"
            android:title="@string/opt_particles_title"
            app:layout="@layout/settings_preference_checkbox_bottom" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/opt_category_animations">

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="dimHitObjects"
            android:summary="@string/opt_dim_hit_objects_summary"
            android:title="@string/opt_dim_hit_objects_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="comboburst"
            android:summary="@string/opt_combo_burst_summary"
            android:title="@string/opt_combo_burst_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="images"
            android:summary="@string/opt_largeimages_summary"
            android:title="@string/opt_largeimages_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="animateFollowCircle"
            android:summary="@string/opt_animate_follow_circle_summary"
            android:title="@string/opt_animate_follow_circle_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="animateComboText"
            android:summary="@string/opt_animate_combo_text_summary"
            android:title="@string/opt_animate_combo_text_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="snakingInSliders"
            android:summary="@string/opt_snakingInSliders_summary"
            android:title="@string/opt_snakingInSliders_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="snakingOutSliders"
            android:summary="@string/opt_snakingOutSliders_summary"
            android:title="@string/opt_snakingOutSliders_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="noChangeDimInBreaks"
            android:summary="@string/opt_noChangeDimInBreaks_summary"
            android:title="@string/opt_noChangeDimInBreaks_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="bursts"
            android:summary="@string/opt_bursts_summary"
            android:title="@string/opt_bursts_title"
            app:layout="@layout/settings_preference_checkbox" />

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="hitlighting"
            android:summary="@string/opt_hitlighting_summary"
            android:title="@string/opt_hitlighting_title"
            app:layout="@layout/settings_preference_checkbox_bottom" />

    </PreferenceCategory>

</androidx.preference.PreferenceScreen>